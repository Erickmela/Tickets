# ============================================
# DJANGO CORE CONFIGURATION
# ============================================
# Secret key for Django (generate with: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=django-insecure-change-this-key-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# QR Code Path
MEDIA_URL=/media/
MEDIA_ROOT=media

# Configuración de la empresa
EMPRESA_NOMBRE=Jala Jala Tickets
EMPRESA_RUC=20123456789
EMPRESA_DIRECCION=Arequipa, Perú

# ============================================
# DATABASE CONFIGURATION
# ============================================
# DATABASE_ENGINE='django.db.backends.postgresql'
# DATABASE_NAME='Tickets'
# DATABASE_USER='postgres'
# DATABASE_PASSWORD='Erickson'
# DATABASE_HOST='localhost'
# DATABASE_PORT='5432'

# ============================================
# TICKET SECURITY - ENCRYPTION KEYS
# ============================================
# AES-256 encryption key (64 hex characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TICKET_ENCRYPTION_KEY=your_64_character_hex_key_for_aes_256_encryption_here

# HMAC-SHA256 signing key (64 hex characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TICKET_HMAC_KEY=your_64_character_hex_key_for_hmac_sha256_signature_here

# ============================================
# REDIS CONFIGURATION (VIRTUAL QUEUE)
# ============================================

# Option 1: Local Redis (Development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Option 2: Upstash Redis (Production - Free tier available)
# REDIS_URL=redis://:your_upstash_password@your_upstash_host:your_upstash_port

# ============================================
# MERCADOPAGO CONFIGURATION
# ============================================
# Get credentials from: https://www.mercadopago.com/developers/panel/app
# Access Token (Backend only - keep secret)
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here
# Public Key (Also used in frontend)
MERCADOPAGO_PUBLIC_KEY=TEST-your-public-key-here
# Webhook Secret (for signature validation)
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret-key-here
# Statement descriptor (appears on credit card statement)
MERCADOPAGO_STATEMENT_DESCRIPTOR=TICKETS

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173